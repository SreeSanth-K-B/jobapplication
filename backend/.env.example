# Environment Variables — Backend
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/job_tracker?retryWrites=true&w=majority

# Google Gemini AI — get free key from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth for Gmail sync — get from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
